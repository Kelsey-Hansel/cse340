<!-- Content Heading -->
<h1>
    <%= title %>
</h1>

<!-- Flash Message -->
<%- messages() %>
<% if (errors) { %>
    <ul class="notice">
    <% errors.array().forEach(error=> { %>
        <li>
            <%= error.msg %>
        </li>
    <% }) %>
    </ul>
<% } %>

<h2>Welcome <%- account_firstname %>!</h2>
<p><a title="Click to update account information." href="/account/update">Update account information.</a></p>
<% if (locals.accountData.account_type === "Employee" || locals.accountData.account_type === "Admin") { %>
    <h3>Inventory Management</h3>
    <p><a title="Click to manage inventory." href="/inv">Manage the inventory.</a></p>
<% } %>