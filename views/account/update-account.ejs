<!-- Content Heading -->
<h1>
    <%= title %>
</h1>

<!-- Flash Message -->
<%- messages() %>
<% if (errors) { %>
    <ul class="notice">
    <% errors.array().forEach(error=> { %>
        <li>
            <%= error.msg %>
        </li>
    <% }) %>
    </ul>
<% } %>

<h2>Account Update:</h2>
<form id="accountUpdateForm" action="/account/update-info" method="post">
    <label for="account_firstname">First Name:</label>
    <input type="text" id="account_firstname" name="account_firstname" required value="<%= account_firstname %>">
    <label for="account_lastname">Last Name:</label>
    <input type="text" id="account_lastname" name="account_lastname" required value="<%= account_lastname %>">
    <label for="account_email">Email Address:</label>
    <input type="email" id="account_email" name="account_email" required value="<%= account_email %>">
    <input type="submit" name="accountUpdate" id="updateAccount" value="Update Account">
    <input type="hidden" name="account_id" <% if(account_id) { %> value="<%= account_id %>" <% } %>>
</form>

<h2>Change Password:</h2>
<form id="passwordUpdateForm" action="/account/update-password" method="post">
    <label for="account_password">Password:</label>
    <input type="password" id="account_password" name="account_password" required
        pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
    <div>
        <p>Enter a password that is at least 12 characters long and has at least 1 uppercase character, 1 number, and 1
            special character. Clicking the button with a new password entered will change your current password.</p>
    </div>
        <input type="submit" name="passwordUpdate" id="updatePassword" value="Update Password">
        <input type="hidden" name="account_id" <% if(account_id) { %> value="<%= account_id %>" <% } %>>
</form>